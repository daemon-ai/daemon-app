{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "desktop-debug",
      "displayName": "Desktop (Debug)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "desktop-release",
      "displayName": "Desktop (Release)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "android",
      "displayName": "Android",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/android.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "ios",
      "displayName": "iOS",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/ios.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "wasm-release",
      "displayName": "WebAssembly (Release)",
      "inherits": "base",
      "toolchainFile": "$env{DAEMON_APP_QT_WASM}/lib/cmake/Qt6/qt.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "CMAKE_C_FLAGS_MINSIZEREL": "-Oz -DNDEBUG",
        "CMAKE_CXX_FLAGS_MINSIZEREL": "-Oz -DNDEBUG",
        "BUILD_TESTING": "OFF",
        "DAEMON_APP_TUI": "OFF",
        "BUILD_SHARED_LIBS": "OFF",
        "CMAKE_CXX_FLAGS": "$env{DAEMON_APP_WASM_CXX_FLAGS}",
        "CMAKE_EXE_LINKER_FLAGS": "$env{DAEMON_APP_WASM_LINKER_FLAGS}",
        "ECM_DIR": "$env{ECM_DIR}",
        "KF_IGNORE_PLATFORM_CHECK": "ON",
        "KATEHIGHLIGHTINGINDEXER_EXECUTABLE": "$env{DAEMON_APP_KATE_INDEXER}"
      }
    }
  ],
  "buildPresets": [
    { "name": "desktop-debug", "configurePreset": "desktop-debug" },
    { "name": "desktop-release", "configurePreset": "desktop-release" },
    { "name": "wasm-release", "configurePreset": "wasm-release" }
  ],
  "testPresets": [
    {
      "name": "desktop-debug",
      "configurePreset": "desktop-debug",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    }
  ]
}
