//
// Windows resource script for daemon-app.exe, configured at CMake time
// (src/DaemonApp/App/CMakeLists.txt) and compiled by windres. Embeds the
// application icon (what Explorer/taskbar/Alt-Tab show) and the VERSIONINFO
// block (what the file Properties dialog and installers read); the numeric
// FILEVERSION fields come from the top-level VERSION file via
// project(VERSION), keeping this in lockstep with the SemVer source of
// truth.

#include <windows.h>

IDI_ICON1 ICON "@DAEMON_APP_RC_ICON@"

VS_VERSION_INFO VERSIONINFO
FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
FILEFLAGS 0x0L
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        // 040904b0 = US English, Unicode codepage (matches the Translation
        // value below).
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "daemon project"
            VALUE "FileDescription", "Daemon - AI agent chat application"
            VALUE "FileVersion", "@PROJECT_VERSION@"
            VALUE "InternalName", "daemon-app"
            VALUE "LegalCopyright", "Copyright (c) 2026 Jarrad Hope. Licensed under MPL-2.0."
            VALUE "OriginalFilename", "daemon-app.exe"
            VALUE "ProductName", "Daemon"
            VALUE "ProductVersion", "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
